# =============================================================================
# AccreditEx Production .gitignore
# Last updated: 2026-02-26 (Production Distribution Audit)
# =============================================================================

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/

# ─── Build Output ────────────────────────────────────────────────────────────
dist/
dist-ssr/
*.local
build_log.txt

# ─── Test & Coverage Output ──────────────────────────────────────────────────
coverage/
test-results/
playwright-report/
.playwright/

# ─── TypeScript Check Dumps ──────────────────────────────────────────────────
tsc-*.txt

# ─── Backup Files ────────────────────────────────────────────────────────────
*.backup.json
*.backup.ts
*.backup.tsx
*.bak
*.old
*.orig

# ─── Snapshots & Exports ─────────────────────────────────────────────────────
*.web.app-*.html

# ─── Editor & IDE ────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db

# ─── Environment Variables & Secrets (CRITICAL) ──────────────────────────────
.env
.env.*
!.env.example
.deploy-config

# ─── Firebase Credentials (CRITICAL) ─────────────────────────────────────────
*firebase-adminsdk*.json
**/*firebase*adminsdk*.json
serviceAccountKey.json
**/serviceAccountKey.json

# ─── Private Keys & Certificates ─────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.db
.venv/
venv/
.pytest_cache/

# ─── AI Agent Artifacts ──────────────────────────────────────────────────────
ai-agent/verify_output.txt
ai-agent/deployment_package/.pytest_cache/
ai-agent/enhanced_deployment_package/*.json

# ─── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
