{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🔍 ReasoningBank: Stats",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/.agentica/scripts/reasoning_bank.py",
      "args": ["stats"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "⚡ Router: Route a task",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/.agentica/scripts/router_cli.py",
      "args": ["add dark mode to the dashboard"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "🧪 Jest: All Tests",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/jest",
      "args": ["--config", "jest.config.ts", "--watchAll=false"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "🎭 Playwright: E2E Tests",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/playwright",
      "args": ["test"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "🌐 Vite: Dev Server",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/vite",
      "args": [],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
