rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =====================================================
    // HELPER FUNCTIONS
    // =====================================================
    // Rewritten 2026-02-20: Flattened role checks to avoid
    // nested ternary evaluation issues.
    // Supports: 1) Firebase Custom Claims  2) Firestore doc lookup
    // =====================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check admin via Custom Claims (fast path, no doc reads)
    function hasAdminClaim() {
      return isAuthenticated() && request.auth.token.role == 'Admin';
    }
    
    // Check admin via Firestore user document (fallback)
    function hasAdminDoc() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    // Super-admin check: platform-level operator only.
    // Grant access by creating a document in /platformAdmins/{uid} via Firebase Console.
    // No Cloud Functions or custom claims required.
    function isSuperAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/platformAdmins/$(request.auth.uid));
    }

    // Unified admin check: custom claim OR Firestore doc
    function isAdmin() {
      return hasAdminClaim() || hasAdminDoc();
    }
    
    // Role lookup for non-admin roles (used by isProjectLead, isAtLeastTeamMember)
    function getUserRole() {
      let claimRole = request.auth.token.role;
      return isAuthenticated()
        ? (claimRole != null
            ? claimRole
            : (exists(/databases/$(database)/documents/users/$(request.auth.uid))
                ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                : null))
        : null;
    }
    
    function isProjectLead() {
      return isAdmin() || getUserRole() == 'ProjectLead';
    }
    
    function isAtLeastTeamMember() {
      return isAdmin() || getUserRole() in ['ProjectLead', 'TeamMember', 'Auditor'];
    }
    
    // Note: Firestore enforces 1MB document size limit automatically
    
    function hasRequiredProjectFields() {
      return request.resource.data.keys().hasAll(['name', 'programId', 'startDate']);
    }
    
    // Prevent privilege escalation on user updates
    function cannotEscalatePrivilege() {
      // Allow if role field is not changing, or if user is admin
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) 
             || request.resource.data.role == resource.data.role 
             || isAdmin();
    }

    // Owners can update their own profile fields, but not tenant or account control fields.
    function ownerCannotChangeProtectedUserFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'organizationId', 'isActive']);
    }

    // Self-registration creates the caller's own profile doc before any org claim exists.
    function ownerCanCreateOwnUserDoc(userId) {
      return isOwner(userId)
        && request.resource.data.keys().hasAll(['email'])
        && request.resource.data.email == request.auth.token.email;
    }
    
    // Check if user is the document owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ── Multi-Tenancy Helpers ──────────────────────────────
    // Get the organizationId from the requesting user's Auth token
    function getUserOrgId() {
      return request.auth.token.organizationId;
    }
    
    // Check if tenant isolation is active for this request
    function isTenantActive() {
      return getUserOrgId() != null;
    }
    
    // Check that document belongs to the user's organization
    // Backward compatible: pass-through when no org claim or legacy doc without orgId
    function belongsToUserOrg() {
      return !isTenantActive()
        || !resource.data.keys().hasAny(['organizationId'])
        || resource.data.organizationId == getUserOrgId();
    }
    
    // Check that new/updated document sets the correct org ID
    // Backward compatible: pass-through when no org claim or no orgId field being set
    function setsCorrectOrg() {
      return !isTenantActive()
        || !request.resource.data.keys().hasAny(['organizationId'])
        || request.resource.data.organizationId == getUserOrgId();
    }
    
    // =====================================================
    // COLLECTION RULES
    // =====================================================
    
    // Metadata collection (system use only)
    match /_metadata/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Users collection
    // Security: Users keyed by Firebase Auth UID
    // Multi-tenancy: Reads filtered by org, writes must set correct org
    match /users/{userId} {
      // Always allow a signed-in user to read their own profile doc.
      // This prevents tenant-claim mismatch edge cases from blocking login hydration.
      allow read: if isAuthenticated() && (isOwner(userId) || belongsToUserOrg());
      allow create: if ownerCanCreateOwnUserDoc(userId)
                    || (isAdmin() && setsCorrectOrg());
      allow update: if (isOwner(userId) && ownerCannotChangeProtectedUserFields())
                    || (isAdmin() && cannotEscalatePrivilege() && setsCorrectOrg());
      allow delete: if isAdmin() 
                    || (isAuthenticated() && resource.data.email == request.auth.token.email);
    }
    
    // Projects collection
    // Security fix (2026-02-18): Update restricted to project leads+
    // instead of any authenticated user (was: allow update: if isAuthenticated())
    match /projects/{projectId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAuthenticated() && hasRequiredProjectFields() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isProjectLead() && belongsToUserOrg();
    }
    
    // Documents collection
    // Security fix: Create/update restricted to team members+
    // (was: any authenticated user — audit finding S-7)
    match /documents/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAtLeastTeamMember() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Standards collection
    match /standards/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create, update: if isAdmin() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Accreditation Programs collection
    match /accreditationPrograms/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create, update: if isAdmin() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Departments collection
    match /departments/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create, update: if isAdmin() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Training Programs collection
    match /trainingPrograms/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isProjectLead() && setsCorrectOrg();
      allow update: if isProjectLead() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Competencies collection
    match /competencies/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create, update: if isAdmin() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Risks collection
    // Security fix: Create/update restricted to team members+
    match /risks/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAtLeastTeamMember() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // App Settings collection
    match /appSettings/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow write: if isAdmin() && setsCorrectOrg();
    }
    
    // Audit Findings collection
    // Security fix: Create/update restricted to team members+
    match /auditFindings/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAtLeastTeamMember() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Settings Audit Logs collection
    // Security fix (2026-02-18): Create restricted to admin only
    // to prevent audit log injection by non-admin users.
    // (was: allow create: if isAuthenticated())
    match /settings_audit_logs/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }
    
    // Settings Versions collection
    match /settings_versions/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Custom Roles collection
    // Security fix (2026-02-18): Added missing rules for custom_roles.
    // Previously had no rules, defaulting to deny-all.
    match /custom_roles/{roleId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Device Sessions collection (for session tracking)
    match /device_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin() || isOwner(sessionId);
    }

    // User-scoped device sessions (actual path used by deviceSessionService)
    // Path: users/{userId}/sessions/{sessionId}
    match /users/{userId}/sessions/{sessionId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create, update: if isAuthenticated()
                            && isOwner(userId)
                            && request.resource.data.userId == userId;
      allow delete: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }
    
    // User Activity Logs collection
    match /user_activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }
    
    // Report Definitions collection (Custom Report Builder)
    // Security fix: Write restricted to project leads+
    match /reportDefinitions/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isProjectLead() && setsCorrectOrg();
      allow update: if isProjectLead() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Workflow Definitions collection (Workflow Automation)
    // Security fix: Write restricted to project leads+
    match /workflowDefinitions/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isProjectLead() && setsCorrectOrg();
      allow update: if isProjectLead() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Workflow Execution Logs collection
    match /workflowExecutionLogs/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAuthenticated() && setsCorrectOrg();
      allow update: if false;
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // ── Additional Collections (Multi-Tenancy) ─────────────
    
    // Organizations collection
    // SECURITY (2026-04-16): Writes restricted to platform super-admins ONLY.
    // Org-level Admins can read their own org doc but CANNOT modify plan, maxUsers,
    // trialEndsAt, subscriptionExpiresAt, or moduleConfig — prevents self-upgrade attacks.
    //
    // EXCEPTION (2026-04-21): Any authenticated user may create ONE org for themselves
    // via self-service registration (free trial flow). The org must have:
    //   - createdBy == auth.uid (can only create for themselves)
    //   - plan == 'professional' and trialActive == true (trial terms enforced)
    //   - All required fields present
    //
    // EXCEPTION (2026-05-XX): Org Admins may activate a one-time 14-day free trial
    // on their own org, restricted to trial fields only, and only when no prior
    // trial has been issued (trialEndsAt field must not exist).
    match /organizations/{orgId} {
      // Any authenticated user can read org docs (org data is not sensitive).
      allow read: if isAuthenticated();
      // Super-admins: full create access.
      // Self-registration: any authenticated user may create an org for themselves
      // (free trial only — plan must be professional, trialActive must be true).
      allow create: if isSuperAdmin() || (
        isAuthenticated() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.plan == 'professional' &&
        request.resource.data.trialActive == true &&
        request.resource.data.isActive == true &&
        request.resource.data.keys().hasAll([
          'name', 'type', 'isActive', 'plan',
          'trialActive', 'trialEndsAt', 'createdAt', 'createdBy'
        ])
      );
      // Super-admins: full update access.
      // Org admins: may self-activate a free trial ONCE (trialActive, trialEndsAt, plan only),
      //   only when the token orgId matches, trial is not active, and trialEndsAt has never been set.
      allow update: if isSuperAdmin() || (
        isAdmin() &&
        isTenantActive() &&
        request.auth.token.organizationId == orgId &&
        !resource.data.get('trialActive', false) &&
        !resource.data.keys().hasAny(['trialEndsAt']) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['trialActive', 'trialEndsAt', 'plan'])
      );
      allow delete: if isSuperAdmin();
    }

    // platformAdmins — stores UID-keyed docs for platform super-admins.
    // Any authenticated user can read their OWN doc (so isSuperAdmin() can evaluate).
    // NOBODY can write from the client — manage via Firebase Console only.
    match /platformAdmins/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if false;
    }
    
    // Audits collection
    match /audits/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAtLeastTeamMember() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Audit Plans collection
    match /auditPlans/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isProjectLead() && setsCorrectOrg();
      allow update: if isProjectLead() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Incident Reports collection
    match /incidentReports/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAtLeastTeamMember() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Quality Rounds collection
    match /quality_rounds/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAtLeastTeamMember() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Rounding Templates collection
    match /rounding_templates/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isProjectLead() && setsCorrectOrg();
      allow update: if isProjectLead() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Rounding Findings collection
    match /rounding_findings/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAtLeastTeamMember() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Performance Evaluations collection
    match /performance_evaluations/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isProjectLead() && setsCorrectOrg();
      allow update: if isProjectLead() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Certificates collection
    match /certificates/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAdmin() && setsCorrectOrg();
      allow update: if isAdmin() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Notifications collection
    // Security fix (2026-04-17): Added belongsToUserOrg() to read/update/delete rules.
    // Previously, read checked userId only — a user from another org could read any
    // notification doc if they knew the document ID.
    match /notifications/{docId} {
      allow read: if isAuthenticated()
                  && belongsToUserOrg()
                  && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && setsCorrectOrg();
      allow update: if isAuthenticated()
                    && belongsToUserOrg()
                    && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
                    && belongsToUserOrg()
                    && resource.data.userId == request.auth.uid;
    }
    
    // Activity Logs collection
    match /activity_logs/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAuthenticated() && setsCorrectOrg();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // Lab Operations Data collection
    // Stores aggregated Lab Ops domain state (equipment, IQC, quality records, etc.)
    match /labOpsData/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAtLeastTeamMember() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Custom Calendar Events collection
    match /customEvents/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAuthenticated() && setsCorrectOrg();
      allow update: if isAuthenticated() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAuthenticated() && belongsToUserOrg();
    }
    
    // Programs collection
    match /programs/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAdmin() && setsCorrectOrg();
      allow update: if isAdmin() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Comments collection (Document Collaboration)
    // Security fix (2026-03-05): Comment collaboration system
    // - Read: Any authenticated user in the same org
    // - Create: Authenticated users with correct author.id
    // - Update/Delete: Only comment author or admin
    match /comments/{commentId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAuthenticated() 
                    && request.resource.data.author.id == request.auth.uid 
                    && setsCorrectOrg();
      allow update, delete: if isAuthenticated() 
                            && (resource.data.author.id == request.auth.uid || isAdmin()) 
                            && belongsToUserOrg();
    }

    // Demo Requests collection (public landing form)
    // Public create is allowed with strict input validation.
    // Read is restricted to admins; update/delete are disabled.
    match /demoRequests/{requestId} {
      allow create: if request.resource.data.keys().hasOnly([
                      'name', 'email', 'organization', 'message', 'createdAt', 'status'
                    ])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() >= 2
                    && request.resource.data.name.size() <= 120
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
                    && request.resource.data.email.size() <= 160
                    && request.resource.data.organization is string
                    && request.resource.data.organization.size() <= 160
                    && request.resource.data.message is string
                    && request.resource.data.message.size() <= 2000
                    && request.resource.data.createdAt is timestamp
                    && request.resource.data.status == 'new';

      allow read: if isAdmin();
      // Super-admins can update status and notes only
      allow update: if isSuperAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'notes']);
      allow delete: if false;
    }

    // ── Branches collection ────────────────────────────────
    // Branches represent physical sub-locations of an organization
    // (e.g. main campus, north branch, satellite clinic).
    // They share the same organizationId as all other org data.
    match /branches/{branchId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create, update: if isAdmin() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }

    // ── Plan enforcement for premium write operations ──────
    // Reads org document to check plan before allowing writes to
    // premium-tier collections (analyticsHub, workflowDefinitions, etc.).
    // Helper function — referenced by premium collection rules.
    // Note: This performs a Firestore read, so it counts against quota.
    function getOrgPlan() {
      let orgId = getUserOrgId();
      return orgId != null
        ? get(/databases/$(database)/documents/organizations/$(orgId)).data.get('plan', 'free')
        : 'free';
    }

    function isAtLeastStarter() {
      let plan = getOrgPlan();
      return plan in ['starter', 'professional', 'enterprise'];
    }

    function isAtLeastProfessional() {
      let plan = getOrgPlan();
      return plan in ['professional', 'enterprise'];
    }

    function isEnterprise() {
      return getOrgPlan() == 'enterprise';
    }

    // Lab Ops Data — Professional+ plan required for writes
    // (read is open to all org members for dashboard visibility)
    match /labOpsDataPremium/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAtLeastTeamMember() && setsCorrectOrg() && isAtLeastProfessional();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg() && isAtLeastProfessional();
      allow delete: if isAdmin() && belongsToUserOrg() && isAtLeastProfessional();
    }

    // Feedback — any authenticated user can submit feedback.
    // Only platform super-admins can read/manage submissions.
    match /feedback/{docId} {
      allow create: if isAuthenticated();
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }
  }
}
