rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =====================================================
    // HELPER FUNCTIONS
    // =====================================================
    // Rewritten 2026-02-20: Flattened role checks to avoid
    // nested ternary evaluation issues.
    // Supports: 1) Firebase Custom Claims  2) Firestore doc lookup
    // =====================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check admin via Custom Claims (fast path, no doc reads)
    function hasAdminClaim() {
      return isAuthenticated() && request.auth.token.role == 'Admin';
    }
    
    // Check admin via Firestore user document (fallback)
    function hasAdminDoc() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    // Unified admin check: custom claim OR Firestore doc
    function isAdmin() {
      return hasAdminClaim() || hasAdminDoc();
    }
    
    // Role lookup for non-admin roles (used by isProjectLead, isAtLeastTeamMember)
    function getUserRole() {
      let claimRole = request.auth.token.role;
      return isAuthenticated()
        ? (claimRole != null
            ? claimRole
            : (exists(/databases/$(database)/documents/users/$(request.auth.uid))
                ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                : null))
        : null;
    }
    
    function isProjectLead() {
      return isAdmin() || getUserRole() == 'ProjectLead';
    }
    
    function isAtLeastTeamMember() {
      return isAdmin() || getUserRole() in ['ProjectLead', 'TeamMember', 'Auditor'];
    }
    
    // Note: Firestore enforces 1MB document size limit automatically
    
    function hasRequiredProjectFields() {
      return request.resource.data.keys().hasAll(['name', 'programId', 'startDate']);
    }
    
    // Prevent privilege escalation on user updates
    function cannotEscalatePrivilege() {
      // Allow if role field is not changing, or if user is admin
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) 
             || request.resource.data.role == resource.data.role 
             || isAdmin();
    }
    
    // Check if user is the document owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ── Multi-Tenancy Helpers ──────────────────────────────
    // Get the organizationId from the requesting user's Auth token
    function getUserOrgId() {
      return request.auth.token.organizationId;
    }
    
    // Check if tenant isolation is active for this request
    function isTenantActive() {
      return getUserOrgId() != null;
    }
    
    // Check that document belongs to the user's organization
    // Backward compatible: pass-through when no org claim or legacy doc without orgId
    function belongsToUserOrg() {
      return !isTenantActive()
        || !resource.data.keys().hasAny(['organizationId'])
        || resource.data.organizationId == getUserOrgId();
    }
    
    // Check that new/updated document sets the correct org ID
    // Backward compatible: pass-through when no org claim or no orgId field being set
    function setsCorrectOrg() {
      return !isTenantActive()
        || !request.resource.data.keys().hasAny(['organizationId'])
        || request.resource.data.organizationId == getUserOrgId();
    }
    
    // =====================================================
    // COLLECTION RULES
    // =====================================================
    
    // Metadata collection (system use only)
    match /_metadata/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Users collection
    // Security: Users keyed by Firebase Auth UID
    // Multi-tenancy: Reads filtered by org, writes must set correct org
    match /users/{userId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if (isAdmin() || isOwner(userId)) && setsCorrectOrg();
      allow update: if (isOwner(userId) || isAdmin()) && cannotEscalatePrivilege() && setsCorrectOrg();
      allow delete: if isAdmin() 
                    || (isAuthenticated() && resource.data.email == request.auth.token.email);
    }
    
    // Projects collection
    // Security fix (2026-02-18): Update restricted to project leads+
    // instead of any authenticated user (was: allow update: if isAuthenticated())
    match /projects/{projectId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAuthenticated() && hasRequiredProjectFields() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isProjectLead() && belongsToUserOrg();
    }
    
    // Documents collection
    // Security fix: Create/update restricted to team members+
    // (was: any authenticated user — audit finding S-7)
    match /documents/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAtLeastTeamMember() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Standards collection
    match /standards/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create, update: if isAdmin() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Accreditation Programs collection
    match /accreditationPrograms/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create, update: if isAdmin() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Departments collection
    match /departments/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create, update: if isAdmin() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Training Programs collection
    match /trainingPrograms/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isProjectLead() && setsCorrectOrg();
      allow update: if isProjectLead() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Competencies collection
    match /competencies/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create, update: if isAdmin() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Risks collection
    // Security fix: Create/update restricted to team members+
    match /risks/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAtLeastTeamMember() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // App Settings collection
    match /appSettings/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow write: if isAdmin() && setsCorrectOrg();
    }
    
    // Audit Findings collection
    // Security fix: Create/update restricted to team members+
    match /auditFindings/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAtLeastTeamMember() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Settings Audit Logs collection
    // Security fix (2026-02-18): Create restricted to admin only
    // to prevent audit log injection by non-admin users.
    // (was: allow create: if isAuthenticated())
    match /settings_audit_logs/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }
    
    // Settings Versions collection
    match /settings_versions/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Custom Roles collection
    // Security fix (2026-02-18): Added missing rules for custom_roles.
    // Previously had no rules, defaulting to deny-all.
    match /custom_roles/{roleId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Device Sessions collection (for session tracking)
    match /device_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin() || isOwner(sessionId);
    }
    
    // User Activity Logs collection
    match /user_activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }
    
    // Report Definitions collection (Custom Report Builder)
    // Security fix: Write restricted to project leads+
    match /reportDefinitions/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isProjectLead() && setsCorrectOrg();
      allow update: if isProjectLead() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Workflow Definitions collection (Workflow Automation)
    // Security fix: Write restricted to project leads+
    match /workflowDefinitions/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isProjectLead() && setsCorrectOrg();
      allow update: if isProjectLead() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Workflow Execution Logs collection
    match /workflowExecutionLogs/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAuthenticated() && setsCorrectOrg();
      allow update: if false;
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // ── Additional Collections (Multi-Tenancy) ─────────────
    
    // Organizations collection (super-admin only)
    match /organizations/{orgId} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.token.organizationId == orgId);
      allow write: if isAdmin();
    }
    
    // Audits collection
    match /audits/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAtLeastTeamMember() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Audit Plans collection
    match /auditPlans/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isProjectLead() && setsCorrectOrg();
      allow update: if isProjectLead() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Incident Reports collection
    match /incidentReports/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAtLeastTeamMember() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Quality Rounds collection
    match /quality_rounds/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAtLeastTeamMember() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Rounding Templates collection
    match /rounding_templates/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isProjectLead() && setsCorrectOrg();
      allow update: if isProjectLead() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Rounding Findings collection
    match /rounding_findings/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAtLeastTeamMember() && setsCorrectOrg();
      allow update: if isAtLeastTeamMember() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Performance Evaluations collection
    match /performance_evaluations/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isProjectLead() && setsCorrectOrg();
      allow update: if isProjectLead() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Certificates collection
    match /certificates/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAdmin() && setsCorrectOrg();
      allow update: if isAdmin() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
    
    // Notifications collection
    match /notifications/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && setsCorrectOrg();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Activity Logs collection
    match /activity_logs/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAuthenticated() && setsCorrectOrg();
      allow update: if false;
      allow delete: if isAdmin();
    }
    
    // Custom Calendar Events collection
    match /customEvents/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAuthenticated() && setsCorrectOrg();
      allow update: if isAuthenticated() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAuthenticated() && belongsToUserOrg();
    }
    
    // Programs collection
    match /programs/{docId} {
      allow read: if isAuthenticated() && belongsToUserOrg();
      allow create: if isAdmin() && setsCorrectOrg();
      allow update: if isAdmin() && belongsToUserOrg() && setsCorrectOrg();
      allow delete: if isAdmin() && belongsToUserOrg();
    }
  }
}
